# ── SENTINEL SOS — Environment Configuration ─────────────────────────────────
# Copy this file to .env and fill in your values

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=sentinelsos
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel123

# Full connection URL for SQLAlchemy / asyncpg
# When running locally against Docker: use localhost
DATABASE_URL=postgresql://sentinel:sentinel123@localhost:5432/sentinelsos

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenStreetMap / Overpass API ──────────────────────────────────────────────
# No API key required — Overpass is free and open
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# ── Nominatim (reverse geocoding) ─────────────────────────────────────────────
# No API key required — Nominatim is free and open
NOMINATIM_URL=https://nominatim.openstreetmap.org

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ── App settings ──────────────────────────────────────────────────────────────
# Default search radius in meters
DEFAULT_SEARCH_RADIUS=5000
