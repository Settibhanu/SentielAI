# Copy this file to .env and fill in your values

# ── PostgreSQL (used by docker-compose and the backend) ───────────────────────
POSTGRES_DB=sentielai
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel123

# Full connection URL for SQLAlchemy / asyncpg
# When running locally against Docker: use localhost
DATABASE_URL=postgresql://sentinel:sentinel123@localhost:5432/sentielai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenWeatherMap (free tier) ────────────────────────────────────────────────
# Sign up at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_key_here
